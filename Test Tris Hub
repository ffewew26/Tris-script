spawn(function()
    while task.wait() do
        if _G.AutoFarm or _G.AutoAttackLevi or _G.AutoDungeon then
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton1(Vector2.new(851, 158), game.Workspace.CurrentCamera.CFrame)
            end)
        end
